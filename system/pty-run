#!/usr/bin/env bash
# pty-run -- run a command inside a real PTY with alt-screen + clipso capture.
#
# Standalone extraction of the pattern validated in:
#   zsh-setup/dotfiles/.addons-zsh/aliass/bindkeys.zsh (_wrap_clipso, _clipso_clean)
# That version only works inside an interactive zsh ($BUFFER, zle). This is the
# same pattern usable from scripts, ssh, cron, or any non-interactive context.
#
# USAGE:
#   pty-run 'cmd1 && cmd2 | cmd3'   # single string arg -> eval (supports && | ; etc)
#   pty-run cmd arg1 arg2           # multiple args -> run directly (no eval, safer)
#
# WHY TWO MODES: same dual-mode contract as the now-removed lipso() helper
# (zsh-setup commit 5fcef68) -- one string when you need shell operators,
# argv form when you don't and want to avoid eval entirely.
#
# WHAT IT DOES:
#   1. alt-screen on   (\033[?1049h) so live output doesn't pollute scrollback
#   2. run the command inside a real PTY via `script -q -e -O <log> -c "<cmd>"`
#      -q = no start/done banner noise, -e = propagate child's real exit code
#   3. alt-screen off  (\033[?1049l)
#   4. strip script(1) banners + ANSI + CR from the captured log
#   5. clipso <log>    -- show clean output and copy it to clipboard
#
# EXIT CODE: propagates the wrapped command's real exit code (via script -e).
set -u

if [ "$#" -eq 0 ]; then
  echo "usage: pty-run 'cmd1 && cmd2' | pty-run cmd arg1 arg2" >&2
  exit 1
fi

if [ "$#" -eq 1 ]; then
  _cmd=$1
else
  _cmd=$(printf '%q ' "$@")
fi

_clean_pty_log() {   # $1 = logfile, normalize script(1) output in place
  sed -i '1{/^Script started/d}; ${/^Script done/d}; s/\x1b\[[0-9;]*[mGKHFABCDJsu]//g; s/\x1b\[?[0-9;]*[hl]//g; s/\r//g' "$1"
}

_log=$(mktemp "${TMPDIR:-/tmp}/pty-run.XXXXXX")

printf '\033[?1049h\033[2J\033[H'
COLUMNS=$(tput cols) LINES=$(tput lines) script -q -e -O "$_log" -c "$_cmd"
_status=$?
printf '\033[?1049l'

_clean_pty_log "$_log"
clipso "$_log"
rm -f "$_log"
exit "$_status"
