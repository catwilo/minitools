#!/usr/bin/env bash
# pty-run -- run a command inside a real PTY with alt-screen + clipso capture.
#
# Standalone extraction of the pattern validated in:
#   zsh-setup/dotfiles/.addons-zsh/aliass/bindkeys.zsh (_wrap_clipso, _clipso_clean)
# That version only works inside an interactive zsh ($BUFFER, zle). This is the
# same pattern usable from scripts, ssh, cron, or any non-interactive context.
#
# USAGE:
#   pty-run [--shell=NAME] 'cmd1 && cmd2 | cmd3'   # single string -> eval (supports && | ; etc)
#   pty-run [--shell=NAME] cmd arg1 arg2           # multiple args -> run directly (no eval, safer)
#
# --shell=NAME picks which shell interprets the command string (bash, zsh, sh, ...).
# Default (no flag): $SHELL, same as plain `script -c` -- matches the user's
# actual interactive shell. Pass --shell explicitly whenever the command uses
# shell-specific syntax (e.g. bash's `read -p` vs zsh's `read 'var?prompt'`)
# so behavior is deterministic instead of guessed from the command's content.
#
# WHY TWO INVOCATION MODES: same dual-mode contract as the now-removed lipso()
# helper (zsh-setup commit 5fcef68) -- one string when you need shell operators,
# argv form when you don't and want to avoid eval entirely.
#
# WHAT IT DOES:
#   1. alt-screen on   (\033[?1049h) so live output doesn't pollute scrollback
#   2. run the command inside a real PTY via `<shell> -c "<cmd>"` wrapped in
#      `script -q -e -O <log> -c "..."` (-q = no banner noise, -e = propagate
#      the child's real exit code)
#   3. alt-screen off  (\033[?1049l)
#   4. strip script(1) banners + ANSI + CR from the captured log
#   5. clipso <log>    -- show clean output and copy it to clipboard
#
# EXIT CODE: propagates the wrapped command's real exit code (via script -e).
set -u

_shell="${SHELL:-/bin/sh}"
case "${1:-}" in
  --shell=*) _shell="${1#--shell=}"; shift ;;
esac

if [ "$#" -eq 0 ]; then
  echo "usage: pty-run [--shell=NAME] 'cmd1 && cmd2' | pty-run [--shell=NAME] cmd arg1 arg2" >&2
  exit 1
fi

command -v "$_shell" >/dev/null 2>&1 || { echo "pty-run: shell not found: $_shell" >&2; exit 1; }

if [ "$#" -eq 1 ]; then
  _cmd=$1
else
  _cmd=$(printf '%q ' "$@")
fi

_clean_pty_log() {   # $1 = logfile, normalize script(1) output in place
  sed -i '1{/^Script started/d}; ${/^Script done/d}; s/\x1b\[[0-9;]*[mGKHFABCDJsu]//g; s/\x1b\[?[0-9;]*[hl]//g; s/\r//g' "$1"
}

_log=$(mktemp "${TMPDIR:-/tmp}/pty-run.XXXXXX")

printf '\033[?1049h\033[2J\033[H'
_cmd_q=$(printf '%s' "$_cmd" | sed "s/'/'\\\\''/g")
_inner="$_shell -c '$_cmd_q'"
COLUMNS=$(tput cols) LINES=$(tput lines) script -q -e -O "$_log" -c "$_inner"
_status=$?
printf '\033[?1049l'

_clean_pty_log "$_log"
clipso "$_log"
rm -f "$_log"
exit "$_status"
