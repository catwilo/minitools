#!/usr/bin/env bash
# fehbg — set wallpaper(s) from a directory using feh
# Usage: fehbg [dir]   default: ~/.local/share/wallpapers
set -euo pipefail

BG_DIR="${1:-${XDG_DATA_HOME:-$HOME/.local/share}/wallpapers}"
[[ -d "$BG_DIR" ]] || { echo "Error: dir not found: $BG_DIR"; exit 1; }

mapfile -t imgs < <(find "$BG_DIR" -maxdepth 1 -type f   \( -name "*.jpg" -o -name "*.jpeg" -o -name "*.png" \) | sort)
[[ ${#imgs[@]} -eq 0 ]] && { echo "No images found in $BG_DIR"; exit 1; }

echo "Applying ${#imgs[@]} wallpaper(s) from $BG_DIR"
feh --no-fehbg --bg-scale "${imgs[@]}"
